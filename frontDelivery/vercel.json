{
  "git": { "deploymentEnabled": false },
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://pizzaburgerdelivery-production.up.railway.app/api/:path*" },
    { "source": "/oauth2/:path*", "destination": "https://pizzaburgerdelivery-production.up.railway.app/oauth2/:path*" },
    { "source": "/login/oauth2/:path*", "destination": "https://pizzaburgerdelivery-production.up.railway.app/login/oauth2/:path*" },
    { "source": "/((?!api/|oauth2/|login/).*)", "destination": "/index.html" }
  ]
}
